@using Mission08_0404.Models
@model IEnumerable<TaskItem>


@{
    ViewData["Title"] = "Task Quadrants Dashboard";

    // if the controller doesn't pass a model yet, treat it as an empty list
    var tasks = (Model ?? Enumerable.Empty<TaskItem>()).ToList();

    // Completed tasks are those with CompletedFlag == 1
    var activeTasks = tasks.Where(t => t.CompletedFlag != 1).ToList();

    // Quadrant is stored as QuadrantId (int)
    var q1 = activeTasks.Where(t => t.QuadrantId == 1).ToList();
    var q2 = activeTasks.Where(t => t.QuadrantId == 2).ToList();
    var q3 = activeTasks.Where(t => t.QuadrantId == 3).ToList();
    var q4 = activeTasks.Where(t => t.QuadrantId == 4).ToList();
}

<div class="container mt-5">

    <div class="text-center mb-4">
        <h1 class="display-4">Task Quadrants Dashboard</h1>

       
        <a class="btn btn-primary"
           asp-controller="Home"
           asp-action="AddEditTasks">
            + Add New Task
        </a>
        
        <a class="btn btn-outline-secondary ms-2"
           asp-controller="Home"
           asp-action="CompletedTasks">
            View Completed
        </a>
    </div>

    <div class="row g-4">
        
        <!-- Quadrant I -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-danger text-white text-center">
                    Quadrant I: Important / Urgent
                </div>
                <div class="card-body">

                    @if (q1.Count == 0)
                    {
                        <div class="text-muted">No tasks.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var task in q1)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">

                                        <div class="me-3">
                                            <!-- CONFIRMED property -->
                                            <div class="fw-semibold">@task.TaskName</div>

                                            <div class="small text-muted">
                                                Due: @task.DueDate.ToString("MMM d, yyyy")

                                                <!-- CONFIRMED Category navigation -->
                                                <span class="ms-2">
                                                    | Category: @(task.Cat?.CatName ?? $"CatId {task.CatId}")
                                                </span>
                                            </div>
                                        </div>

                                        <div class="d-flex gap-2">

                                            <!-- EDIT: CONFIRMED action -->
                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-controller="Home"
                                               asp-action="AddEditTasks"
                                               asp-route-id="@task.TaskId">
                                                Edit
                                            </a>

                                            <!-- DELETE -->
                                            <form method="post"
                                                  asp-controller="Home"
                                                  asp-action="DeleteTask"
                                                  asp-route-id="@task.TaskId">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger"
                                                        >
                                                    Delete
                                                </button>
                                            </form>

                                            <!-- COMPLETE -->
                                            <form method="post"
                                                  asp-controller="Home"
                                                  asp-action="CompleteTask"
                                                  asp-route-id="@task.TaskId">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="btn btn-sm btn-success"
                                                        >
                                                    Complete
                                                </button>
                                            </form>

                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                </div>
            </div>
        </div>


        <!-- Quadrant II -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white text-center">
                    Quadrant II: Important / Not Urgent
                </div>
                <div class="card-body">

                    @if (q2.Count == 0)
                    {
                        <div class="text-muted">No tasks.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var task in q2)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">

                                        <div class="me-3">
                                            <div class="fw-semibold">@task.TaskName</div>

                                            <div class="small text-muted">
                                                Due: @task.DueDate.ToString("MMM d, yyyy")
                                                <span class="ms-2">| Category: @(task.Cat?.CatName ?? $"CatId {task.CatId}")</span>
                                            </div>
                                        </div>

                                        <div class="d-flex gap-2">
                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-controller="Home"
                                               asp-action="AddEditTasks"
                                               asp-route-id="@task.TaskId">
                                                Edit
                                            </a>

                                            <form method="post"
                                                  asp-controller="Home"
                                                  asp-action="DeleteTask"
                                                  asp-route-id="@task.TaskId">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    Delete
                                                </button>
                                            </form>

                                            <form method="post"
                                                  asp-controller="Home"
                                                  asp-action="CompleteTask"
                                                  asp-route-id="@task.TaskId">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    Complete
                                                </button>
                                            </form>
                                        </div>

                                    </div>
                                </div>
                            }
                        </div>
                    }

                </div>
            </div>
        </div>
        
        <!-- Quadrant III -->

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-warning text-dark text-center">
                    Quadrant III: Not Important / Urgent
                </div>
                <div class="card-body">

                    @if (q3.Count == 0)
                    {
                        <div class="text-muted">No tasks.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var task in q3)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">

                                        <div class="me-3">
                                            <div class="fw-semibold">@task.TaskName</div>

                                            <div class="small text-muted">
                                                Due: @task.DueDate.ToString("MMM d, yyyy")
                                                <span class="ms-2">| Category: @(task.Cat?.CatName ?? $"CatId {task.CatId}")</span>
                                            </div>
                                        </div>

                                        <div class="d-flex gap-2">
                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-controller="Home"
                                               asp-action="AddEditTasks"
                                               asp-route-id="@task.TaskId">
                                                Edit
                                            </a>

                                            <form method="post"
                                                  asp-controller="Home"
                                                  asp-action="DeleteTask"
                                                  asp-route-id="@task.TaskId">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    Delete
                                                </button>
                                            </form>

                                            <form method="post"
                                                  asp-controller="Home"
                                                  asp-action="CompleteTask"
                                                  asp-route-id="@task.TaskId">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    Complete
                                                </button>
                                            </form>
                                        </div>

                                    </div>
                                </div>
                            }
                        </div>
                    }

                </div>
            </div>
        </div>
        
        <!-- Quadrant IV -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-secondary text-white text-center">
                    Quadrant IV: Not Important / Not Urgent
                </div>
                <div class="card-body">

                    @if (q4.Count == 0)
                    {
                        <div class="text-muted">No tasks.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var task in q4)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">

                                        <div class="me-3">
                                            <div class="fw-semibold">@task.TaskName</div>

                                            <div class="small text-muted">
                                                Due: @task.DueDate.ToString("MMM d, yyyy")
                                                <span class="ms-2">| Category: @(task.Cat?.CatName ?? $"CatId {task.CatId}")</span>
                                            </div>
                                        </div>

                                        <div class="d-flex gap-2">
                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-controller="Home"
                                               asp-action="AddEditTasks"
                                               asp-route-id="@task.TaskId">
                                                Edit
                                            </a>

                                            <form method="post"
                                                  asp-controller="Home"
                                                  asp-action="DeleteTask"
                                                  asp-route-id="@task.TaskId">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    Delete
                                                </button>
                                            </form>

                                            <form method="post"
                                                  asp-controller="Home"
                                                  asp-action="CompleteTask"
                                                  asp-route-id="@task.TaskId">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    Complete
                                                </button>
                                            </form>
                                        </div>

                                    </div>
                                </div>
                            }
                        </div>
                    }

                </div>
            </div>
        </div>

    </div>
</div>